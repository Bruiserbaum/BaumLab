# ── Authentication ─────────────────────────────────────────────────────────────
# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_HEX_SECRET

# Initial admin account — created automatically on first start if no users exist.
# Once created, changing these values here has no effect (edit the account in the UI).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD

# How long login tokens stay valid (hours). Default: 8
TOKEN_EXPIRE_HOURS=8

# ── Ports (optional overrides) ─────────────────────────────────────────────────
# Change if these ports are already in use on your host
API_PORT=8100
UI_PORT=3100

# ── Authentik SSO (optional) ───────────────────────────────────────────────────
# Enable OIDC login via Authentik. When enabled, a "Login with Authentik" button
# appears on the login page alongside the existing username/password form.
#
# In Authentik: create an OAuth2/OpenID Provider + Application.
# Redirect URI to register in Authentik:
#   http://your-server:8100/api/auth/oidc/callback
#   (or https://baumlab.yourdomain.com/api/auth/oidc/callback if behind a reverse proxy)
#
# OIDC_ENABLED=true
# OIDC_ISSUER=https://auth.yourdomain.com/application/o/<app-slug>/
# OIDC_CLIENT_ID=REPLACE_WITH_CLIENT_ID
# OIDC_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
# OIDC_REDIRECT_URI=http://your-server:8100/api/auth/oidc/callback
#
# Only required when API and frontend are on different ports with no shared reverse proxy.
# Leave unset if both are behind the same proxy at a single domain.
# OIDC_FRONTEND_URL=http://your-server:3100
