# ── Authentication ─────────────────────────────────────────────────────────────
# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_HEX_SECRET

# Initial admin account — created automatically on first start if no users exist.
# Once created, changing these values here has no effect (edit the account in the UI).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD

# How long login tokens stay valid (hours). Default: 8
TOKEN_EXPIRE_HOURS=8

# ── Ports (optional overrides) ─────────────────────────────────────────────────
# Change if these ports are already in use on your host
API_PORT=8100
UI_PORT=3100
